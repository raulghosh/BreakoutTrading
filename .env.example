# Copy to .env and fill in. Never commit .env.

# --- Alpaca (bulk market data + news) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Use the data feed you are entitled to: "iex" (free) or "sip" (paid, full tape).
ALPACA_DATA_FEED=iex
# Set to "true" for a paper trading account, "false" for a live trading account.
# Only affects the universe endpoint (get_all_assets); bar data is feed-agnostic.
ALPACA_PAPER=true

# --- Schwab Trader API (cross-check, intraday, options, fundamentals) ---
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=.schwab_token.json

# --- LLM catalyst scoring (Phase 5) ---
ANTHROPIC_API_KEY=
